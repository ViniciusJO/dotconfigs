{
    "layer": "top", // Waybar at top layer
    "position": "top",
    "height": 25, // Waybar height (to be removed for auto height)
    //"spacing": 2, // Gaps between modules (4px)

    // Choose the order of the modules
    "modules-left": [
        "hyprland/workspaces",
        "custom/spotify"
    ],
    "modules-center": [
        "hyprland/window"
    ],
    "modules-right": [
//        "network",
        "pulseaudio",
        "pulseaudio#mic",
//	      "battery",
//        "cpu",
//        "memory",
        "clock#calendar",
        "clock",
	      "tray"
    ],

    // Modules
    "jack": {
      "format": "DSP {}%",
      "format-xrun": "{xruns} xruns",
      "format-disconnected": "DSP off",
      "realtime": true
    },
    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{icon}",
        "persistent-workspaces": {"*": 10},
        "format-icons": {
//            "1": "蟀 ",
//            "2": "蟀叴 ",
//            "3": "蟊倹 ",
//            "4": "蟀槮 ",
//            "5": "蟀喖 ",
//            "9": "蟀崻 ",
//            "10": "蟀珨 ",
            "urgent": "蟀棖",
            "focused": "蟀惥",
            "active": "蟀惥",
            "default": "蟀惤"
        }
    },
    "hyprland/window": {
        "max-length": 60
    },
    "clock#calendar": {
        "format": "蟀笚 {:%D}",
        "format-alt": "蟀笚 {:%A, %B %d, %Y}"
    },
    "clock": {
        "format": "蟀厫 {:%H:%M}",
        "format-alt": "蟀厫 {:%I:%M %p}"
    },
    "cpu": {
        "format": "{usage:2}% 蟀崨"
    },
    "memory": {
        "format": "{}% 蟀崪"
    },
    "battery": {
        "bat": "BAT0",
        "states": {
            "warning": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% {icon}蟊悓",
        "format-icons": [
            "蟀伜",
            "蟀伝",
            "蟀伡",
            "蟀伣",
            "蟀伨",
            "蟀伩",
            "蟀個",
            "蟀倎",
            "蟀倐",
            "蟀伖"
        ]
    },
    "network": {
        "format-wifi": "{essid} {icon}",
        "tooltip-format-wifi": "{essid}: {ipaddr}/{cidr} ({signalStrength}%) {icon}",
        "format-ethernet": "{ipaddr}/{cidr} 蟀垇",
        "tooltip-format-ethernet": "{ifname}: {ipaddr}/{cidr} 蟀垇",
        "format-disconnected": "Disconnected 蟀ぎ",
        "format-icons": [
            "蟀",
            "蟀あ",
            "蟀ぅ",
            "蟀え"
        ]
    },
    "pulseaudio": {
        "format": "{volume}% {icon}",
        "format-bluetooth": "{volume}% {icon}蟀偘",
        "format-muted": "蟀潫",
        "format-icons": {
            "headphones": "蟀媼",
            "handsfree": "蟀嫀",
            "headset": "蟀嫀",
            "phone": "蟀劀",
            "portable": "蟀摱",
            "default": [
                "蟀暱",
                "蟀杸",
                "蟀暰"
            ]
        },
        "on-click": "alacritty -e pulsemixer"
    },
    "pulseaudio#mic": {
      "format": "{format_source}",
	    "format-source": "蟀崿",
	    "format-source-muted": "蟀嵀",
	    "tooltip-format": "Mic: {format_source}",
      "on-click": "pactl set-source-mute @DEFAULT_SOURCE@ toggle"
    },
    "bluetooth": {
        "format": "{status} 蟀偗",
        "format-connected": "{device_alias} 蟀偙",
        "format-connected-battery": "{device_alias} {device_battery_percentage}% 蟀",
        "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
        "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
        "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%"
    },
    "tray": {
    	"icon-size": 16,
	    "spacing": 10
    },
    "custom/spotify": {
        "format": "蟀搰 {}",
        "max-length": 40,
        "exec": "$HOME/.config/waybar/custom-modules/spotify.py 2> /dev/null",
        "exec-if": "pgrep spotify",
        "on-click": "playerctl -p spotify play-pause"
    },
    "custom/nordvpn": {
        "format": "蟀窎 {}",
        "max-length": 30,
        "interval": 4,
        "exec": "$HOME/.config/waybar/custom-modules/nordvpn.py 2> /dev/null",
        "exec-if": "pgrep openvpn"
    }
}
